# ============================================================
# ResumeIQ — Environment Variables Example
# Copy this file to .env and fill in all values before starting
# NEVER commit .env — it is in .gitignore
# ============================================================

# ---- Application -------------------------------------------
APP_ENV=development                        # development | staging | production
APP_VERSION=0.1.0
SECRET_KEY=replace-with-a-random-64-char-hex-string

# ---- PostgreSQL --------------------------------------------
# Full DSN used by SQLAlchemy / asyncpg
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/resumeiq
# Raw psycopg2 URL used for migrations (Alembic)
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/resumeiq

POSTGRES_USER=resumeiq_user
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=resumeiq
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---- Google / Gemini ---------------------------------------
# API key for Gemini (Google AI Studio or Vertex AI)
GOOGLE_API_KEY=replace-with-your-gemini-api-key
# Gemini model to use (gemini-2.0-flash-exp recommended for grounding)
GEMINI_MODEL=gemini-2.0-flash-exp
# Google Cloud project ID (required for Vertex AI / Agent Builder)
GOOGLE_CLOUD_PROJECT=replace-with-your-gcp-project-id
# Google Cloud region
GOOGLE_CLOUD_REGION=us-central1
# Path to GCP service account JSON key file (for server-side auth)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# ---- Google Cloud Agent Builder ----------------------------
# Agent resource name from Agent Builder console
AGENT_BUILDER_AGENT_NAME=projects/{project}/locations/{location}/agents/{agent-id}

# ---- MongoDB MCP Server (Partner Track — Mandatory) --------
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=resumeiq
# MCP server endpoint (Google Cloud Agent Builder MCP runtime)
MCP_SERVER_URL=https://replace-with-your-mcp-server-endpoint
MCP_API_KEY=replace-with-mcp-api-key

# ---- Google Drive Export (Bonus Feature) -------------------
# OAuth2 client credentials (download from GCP Console → APIs → Credentials)
GOOGLE_DRIVE_CLIENT_ID=replace-with-oauth-client-id
GOOGLE_DRIVE_CLIENT_SECRET=replace-with-oauth-client-secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ---- Rate Limiting -----------------------------------------
# Max POST requests per IP per hour on /resume/ endpoints
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=3600

# ---- File Upload -------------------------------------------
MAX_FILE_SIZE_MB=5
ALLOWED_EXTENSIONS=pdf,docx

# ---- CORS --------------------------------------------------
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Frontend (Vite prefix — VITE_ vars exposed to browser) -
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=ResumeIQ
