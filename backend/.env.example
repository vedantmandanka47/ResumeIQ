# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/resumeiq

# Gemini / Google Cloud
GOOGLE_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RESUME_MODEL=gemini-2.5-flash
# Optional for Google AI Studio API keys; only needed for Google Cloud integrations.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# MongoDB MCP
MONGODB_MCP_SERVER_URL=https://replace-with-your-mcp-server-endpoint
MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DATABASE=resumeiq
MONGODB_COLLECTION=analyses

# Google Drive
GOOGLE_DRIVE_CLIENT_ID=replace-with-oauth-client-id
GOOGLE_DRIVE_CLIENT_SECRET=replace-with-oauth-client-secret
GOOGLE_DRIVE_REFRESH_TOKEN=replace-with-oauth-refresh-token

# Rate limiting and application
RATE_LIMIT_POST=10/hour
APP_VERSION=0.1.0
MAX_FILE_SIZE_MB=5
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: set to enable Redis-backed rate limiting across workers
# REDIS_URL=redis://localhost:6379/0

# Cover letter feature
COVER_LETTER_MAX_RETRIES=2

# JD URL extraction grounding
JD_URL_EXTRACTION_ENABLED=true
